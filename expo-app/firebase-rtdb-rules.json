{
  "rules": {
    "users": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && auth.uid == $uid",
        ".indexOn": ["username", "inviteCode"],
        "wallet": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid == $uid"
        },
        "inviteCode": {
          ".read": true,
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    },
    "presence": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "friendships": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        "$friendUid": {
          ".write": "auth != null && (auth.uid == $uid || auth.uid == $friendUid)"
        }
      }
    },
    "friendRequests": {
      ".read": "auth != null",
      ".indexOn": ["toUserId", "fromUserId", "status"],
      "$requestId": {
        ".write": "auth != null && (!data.exists() || data.child('fromUserId').val() === auth.uid || data.child('toUserId').val() === auth.uid)"
      }
    },
    "rooms": {
      "$roomCode": {
        ".read": true,
        ".write": "auth != null && (!data.exists() || data.child('hostId').val() === auth.uid)",
        "players": {
          "$playerId": {
            ".write": "auth != null && (auth.uid == $playerId || data.parent().parent().child('hostId').val() === auth.uid)"
          }
        },
        "status": {
          ".write": "auth != null && data.parent().child('hostId').val() === auth.uid"
        }
      }
    },
    "sessions": {
      "$sessionId": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('hostId').val() === auth.uid)",
        "actions": {
          "$actionId": {
            ".write": "auth != null"
          }
        },
        "gameState": {
          ".write": "auth != null && data.parent().child('hostId').val() === auth.uid"
        }
      }
    },
    "telemetry": {
      "$eventId": {
        ".read": false,
        ".write": "auth != null"
      }
    }
  }
}
